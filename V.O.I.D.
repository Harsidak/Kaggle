    "\n",
    "\n",
    "class ProbeAgent(Agent):\n",
    "    \"\"\"\n",
    "    Probes the environment to understand:\n",
    "    1. FrameData structure at each step\n",
    "    2. Grid format (shape, dtype, encoding)\n",
    "    3. Available actions format\n",
    "    4. State transitions (what changes when)\n",
    "    5. Reward signals\n",
    "    \"\"\"\n",
    "    MAX_PROBE_STEPS = 50  # Stop after 50 steps to avoid burning budget\n",
    "    \n",
    "    def __init__(self, *args: Any, **kwargs: Any) -> None:\n",
    "        super().__init__(*args, **kwargs)\n",
    "        self.seed = int(time.time() * 1000000) + hash(self.game_id) % 1000000\n",
    "        random.seed(self.seed)\n",
    "        \n",
    "        self.probe_log = []\n",
    "        self.step_count = 0\n",
    "        self.last_frame = None\n",
    "        self.seen_actions = set()\n",
    "        \n",
    "        # Try each base action systematically\n",
    "        self.action_sequence = [\n",
    "            GameAction.RESET,\n",
    "            GameAction.ACTION1, GameAction.ACTION1,\n",
    "            GameAction.ACTION2, GameAction.ACTION2,\n",
    "            GameAction.ACTION3, GameAction.ACTION3,\n",
    "            GameAction.ACTION4, GameAction.ACTION4,\n",
    "            GameAction.ACTION5, GameAction.ACTION5,\n",
    "            GameAction.ACTION6, GameAction.ACTION6,\n",
    "            GameAction.ACTION7, GameAction.ACTION7,\n",
    "        ]\n",
    "        self.action_idx = 0\n",
    "        \n",
    "        print(f\"\\n{'='*60}\")\n",
    "        print(f\"PROBE AGENT INITIALIZED\")\n",
    "        print(f\"Game ID: {self.game_id}\")\n",
    "        print(f\"Seed: {self.seed}\")\n",
    "        print(f\"{'='*60}\\n\")\n",
    "\n",
    "    def _deep_inspect(self, obj: Any, name: str = \"obj\", max_depth: int = 3, depth: int = 0) -> dict:\n",
    "        \"\"\"Recursively inspect any object, handling pydantic models, numpy arrays, etc.\"\"\"\n",
    "        if depth > max_depth:\n",
    "            return f\"<max_depth_reached: {type(obj).__name__}>\"\n",
    "        \n",
    "        # Handle None\n",
    "        if obj is None:\n",
    "            return None\n",
    "        \n",
    "        # Handle primitives\n",
    "        if isinstance(obj, (str, int, float, bool)):\n",
    "            return obj\n",
    "        \n",
    "        # Handle numpy arrays\n",
    "        if isinstance(obj, np.ndarray):\n",
    "            return {\n",
    "                \"type\": \"numpy.ndarray\",\n",
    "                \"dtype\": str(obj.dtype),\n",
    "                \"shape\": obj.shape,\n",
    "                \"size\": obj.size,\n",
    "                \"min\": int(obj.min()) if obj.size > 0 else None,\n",
    "                \"max\": int(obj.max()) if obj.size > 0 else None,\n",
    "                \"sample\": obj.flatten()[:20].tolist() if obj.size > 0 else [],\n",
    "            }\n",
    "        \n",
    "        # Handle lists\n",
    "        if isinstance(obj, list):\n",
    "            if len(obj) == 0:\n",
    "                return {\"type\": \"list\", \"len\": 0}\n",
    "            # Check if homogeneous\n",
    "            first_type = type(obj[0]).__name__\n",
    "            sample = obj[:5]\n",
    "            return {\n",
    "                \"type\": \"list\",\n",
    "                \"len\": len(obj),\n",
    "                \"element_type\": first_type,\n",
    "                \"sample\": [self._deep_inspect(x, max_depth=max_depth, depth=depth+1) for x in sample],\n",
    "            }\n",
    "        \n",
    "        # Handle dicts\n",
    "        if isinstance(obj, dict):\n",
    "            return {\n",
    "                \"type\": \"dict\",\n",
    "                \"keys\": list(obj.keys()),\n",
    "                \"sample\": {k: self._deep_inspect(v, k, max_depth, depth+1) \n",
    "                          for k, v in list(obj.items())[:5]},\n",
    "            }\n",
    "        \n",
    "        # Handle Pydantic models (FrameData, etc.)\n",
    "        if hasattr(obj, \"model_dump\"):\n",
    "            try:\n",
    "                return {\n",
    "                    \"type\": f\"pydantic:{type(obj).__name__}\",\n",
    "                    \"fields\": self._deep_inspect(obj.model_dump(), max_depth=max_depth, depth=depth+1),\n",
    "                }\n",
    "            except:\n",
    "                pass\n",
    "        \n",
    "        # Handle objects with __dict__\n",
    "        if hasattr(obj, \"__dict__\"):\n",
    "            return {\n",
    "                \"type\": f\"object:{type(obj).__name__}\",\n",
    "                \"attrs\": {k: self._deep_inspect(v, k, max_depth, depth+1) \n",
    "                         for k, v in vars(obj).items() if not k.startswith(\"_\")},\n",
    "            }\n",
    "        \n",
    "        # Fallback\n",
    "        return {\"type\": type(obj).__name__, \"repr\": repr(obj)[:200]}\n",
    "\n",
    "    def _log_step(self, frames: list, latest_frame: FrameData, action_taken: Any, \n",
    "                  action_name: str, phase: str = \"pre-action\"):\n",
    "        \"\"\"Log the complete state of the environment at this step.\"\"\"\n",
    "        log_entry = {\n",
    "            \"step\": self.step_count,\n",
    "            \"phase\": phase,\n",
    "            \"action_taken\": action_name,\n",
    "            \"timestamp\": time.time(),\n",
    "        }\n",
    "        \n",
    "        # Inspect latest_frame deeply\n",
    "        log_entry[\"latest_frame\"] = self._deep_inspect(latest_frame, \"latest_frame\")\n",
    "        \n",
    "        # Inspect frames history\n",
    "        log_entry[\"num_frames_in_history\"] = len(frames)\n",
    "        \n",
    "        # If we have a previous frame, compute diff\n",
    "        if self.last_frame is not None and phase == \"post-action\":\n",
    "            try:\n",
    "                prev_grid = np.array(getattr(self.last_frame, \"frame\", []), dtype=np.int32)\n",
    "                curr_grid = np.array(getattr(latest_frame, \"frame\", []), dtype=np.int32)\n",
    "                \n",
    "                if prev_grid.size > 0 and curr_grid.size > 0 and prev_grid.shape == curr_grid.shape:\n",
    "                    diff = curr_grid != prev_grid\n",
    "                    log_entry[\"diff\"] = {\n",
    "                        \"shape\": prev_grid.shape,\n",
    "                        \"pixels_changed\": int(np.sum(diff)),\n",
    "                        \"prev_unique_colors\": [int(x) for x in np.unique(prev_grid)],\n",
    "                        \"curr_unique_colors\": [int(x) for x in np.unique(curr_grid)],\n",
    "                        \"changed_positions\": np.argwhere(diff)[:10].tolist() if np.sum(diff) > 0 else [],\n",
    "                    }\n",
    "                else:\n",
    "                    log_entry[\"diff\"] = {\n",
    "                        \"prev_shape\": prev_grid.shape if prev_grid.size > 0 else None,\n",
    "                        \"curr_shape\": curr_grid.shape if curr_grid.size > 0 else None,\n",
    "                        \"note\": \"shape mismatch or empty grid\",\n",
    "                    }\n",
    "            except Exception as e:\n",
    "                log_entry[\"diff_error\"] = str(e)\n",
    "        \n",
    "        self.probe_log.append(log_entry)\n",
    "        \n",
    "        # Print concise summary to stdout\n",
    "        frame_data = getattr(latest_frame, \"frame\", None)\n",
    "        state = getattr(latest_frame, \"state\", \"UNKNOWN\")\n",
    "        avail = getattr(latest_frame, \"available_actions\", [])\n",
    "        \n",
    "        grid_info = \"empty\"\n",
    "        if frame_data is not None and len(frame_data) > 0:\n",
    "            try:\n",
    "                arr = np.array(frame_data)\n",
    "                grid_info = f\"shape={arr.shape}, dtype={arr.dtype}\"\n",
    "            except:\n",
    "                grid_info = f\"type={type(frame_data).__name__}, len={len(frame_data) if hasattr(frame_data, '__len__') else 'N/A'}\"\n",
    "        \n",
    "        print(f\"[Step {self.step_count:3d}] {phase:12s} | Action: {action_name:20s} | \"\n",
    "              f\"State: {str(state):15s} | Grid: {grid_info:30s} | \"\n",
    "              f\"ValidActions: {len(avail)}\")\n",
    "\n",
    "    def _save_probe_results(self):\n",
    "        \"\"\"Save all probe data to disk for analysis.\"\"\"\n",
    "        output_path = \"/kaggle/working/probe_results.json\"\n",
    "        try:\n",
    "            with open(output_path, \"w\") as f:\n",
    "                json.dump(self.probe_log, f, indent=2, default=str)\n",
    "            print(f\"\\n{'='*60}\")\n",
    "            print(f\"PROBE RESULTS SAVED TO: {output_path}\")\n",
    "            print(f\"Total steps logged: {len(self.probe_log)}\")\n",
    "            print(f\"{'='*60}\")\n",
    "        except Exception as e:\n",
    "            print(f\"Failed to save probe results: {e}\")\n",
    "        \n",
    "        # Also print a summary\n",
    "        print(\"\\n\" + \"=\"*60)\n",
    "        print(\"PROBE SUMMARY\")\n",
    "        print(\"=\"*60)\n",
    "        \n",
    "        states_seen = set()\n",
    "        grids_seen = []\n",
    "        actions_effective = []\n",
    "        \n",
    "        for entry in self.probe_log:\n",
    "            if entry[\"phase\"] != \"post-action\":\n",
    "                continue\n",
    "            frame = entry.get(\"latest_frame\", {})\n",
    "            fields = frame.get(\"fields\", {}) if isinstance(frame, dict) else {}\n",
    "            state = fields.get(\"state\", \"UNKNOWN\") if isinstance(fields, dict) else \"UNKNOWN\"\n",
    "            states_seen.add(state)\n",
    "            \n",
    "            diff = entry.get(\"diff\", {})\n",
    "            if isinstance(diff, dict) and \"pixels_changed\" in diff:\n",
    "                grids_seen.append(diff[\"shape\"])\n",
    "                if diff[\"pixels_changed\"] > 0:\n",
    "                    actions_effective.append(entry[\"action_taken\"])\n",
    "        \n",
    "        print(f\"States encountered: {states_seen}\")\n",
    "        print(f\"Grid shapes seen: {set(tuple(s) for s in grids_seen if s)}\")\n",
    "        print(f\"Actions that caused change: {set(actions_effective)}\")\n",
    "        print(f\"Total unique actions tried: {self.seen_actions}\")\n",
    "        print(\"=\"*60)\n",
    "\n",
    "    def is_done(self, frames: list[FrameData], latest_frame: FrameData) -> bool:\n",
    "        self._log_step(frames, latest_frame, \"N/A\", \"is_done_check\", phase=\"post-action\")\n",
    "        self.last_frame = latest_frame\n",
    "        \n",
    "        if latest_frame.state is GameState.WIN:\n",
    "            print(f\"\\n{'='*60}\")\n",
    "            print(\"WIN DETECTED! Saving probe results...\")\n",
    "            print(f\"{'='*60}\")\n",
    "            self._save_probe_results()\n",
    "            return True\n",
    "        \n",
    "        if self.step_count >= self.MAX_PROBE_STEPS:\n",
    "            print(f\"\\n{'='*60}\")\n",
    "            print(f\"MAX_PROBE_STEPS ({self.MAX_PROBE_STEPS}) reached. Saving results...\")\n",
    "            print(f\"{'='*60}\")\n",
    "            self._save_probe_results()\n",
    "            return True\n",
    "        \n",
    "        return False\n",
    "\n",
    "    def choose_action(self, frames: list[FrameData], latest_frame: FrameData) -> GameAction:\n",
    "        self.step_count += 1\n",
    "        \n",
    "        # Log pre-action state\n",
    "        self._log_step(frames, latest_frame, \"N/A\", \"pre-choose\", phase=\"pre-action\")\n",
    "        \n",
    "        # Determine action\n",
    "        if latest_frame.state in [GameState.NOT_PLAYED, GameState.GAME_OVER]:\n",
    "            action = GameAction.RESET\n",
    "            action_name = \"RESET\"\n",
    "        else:\n",
    "            # Systematic action testing\n",
    "            if self.action_idx < len(self.action_sequence):\n",
    "                action = self.action_sequence[self.action_idx]\n",
    "                self.action_idx += 1\n",
    "            else:\n",
    "                # After exhausting sequence, random exploration\n",
    "                action = random.choice([a for a in GameAction if a is not GameAction.RESET])\n",
    "            \n",
    "            action_name = action.name if hasattr(action, \"name\") else str(action)\n",
    "            self.seen_actions.add(action_name)\n",
    "        \n",
    "        # Log post-action (will be captured in next is_done or pre-action)\n",
    "        # We can't log the effect yet — it happens after we return\n",
    "        \n",
    "        return action\n",
